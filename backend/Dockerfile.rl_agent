FROM python:3.12-slim

WORKDIR /app

# Install uv for fast dependency management
COPY --from=ghcr.io/astral-sh/uv:latest /uv /usr/local/bin/uv

# Copy dependency files
COPY pyproject.toml .
COPY requirements.txt .

# Install dependencies
RUN uv pip install --system --no-cache -r requirements.txt gymnasium pettingzoo numpy

# Copy source code
COPY src/ src/

# Expose port
EXPOSE 8081

# Run the RL agent microservice
CMD ["uvicorn", "src.rl_agent.main:app", "--host", "0.0.0.0", "--port", "8081"]
